generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum HouseholdRole {
  OWNER
  MEMBER
}

enum TaskCadence {
  ONE_TIME
  RECURRING
}

enum TaskActivityType {
  CREATED
  CLAIMED
  COMPLETED
  HELP_REQUESTED
  UNCLAIMED
}

model User {
  id             String            @id @default(cuid())
  name           String
  email          String            @unique
  passwordHash   String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  memberships    HouseholdMember[]
  createdHouseholds Household[]     @relation("HouseholdCreatedBy")
  createdTasks   Task[]            @relation("TaskCreatedBy")
  claimedTasks   Task[]            @relation("TaskClaimedBy")
  activities     TaskActivity[]
}

model Household {
  id          String            @id @default(cuid())
  name        String
  inviteCode  String            @unique
  createdById String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  createdBy   User              @relation("HouseholdCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  members     HouseholdMember[]
  tasks       Task[]
}

model HouseholdMember {
  id          String         @id @default(cuid())
  userId      String
  householdId String
  role        HouseholdRole  @default(MEMBER)
  joinedAt    DateTime       @default(now())

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  household   Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([userId, householdId])
  @@index([householdId])
}

model Task {
  id               String         @id @default(cuid())
  householdId      String
  createdById      String
  claimedById      String?
  title            String
  details          String?
  cadence          TaskCadence    @default(ONE_TIME)
  repeatEveryDays  Int?
  dueAt            DateTime?
  completedAt      DateTime?
  claimedAt        DateTime?
  helpRequestedAt  DateTime?
  helpNote         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  household        Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy        User           @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  claimedBy        User?          @relation("TaskClaimedBy", fields: [claimedById], references: [id], onDelete: SetNull)
  activities       TaskActivity[]

  @@index([householdId])
  @@index([claimedById])
}

model TaskActivity {
  id          String           @id @default(cuid())
  taskId      String
  actorId     String
  type        TaskActivityType
  note        String?
  createdAt   DateTime         @default(now())

  task        Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor       User             @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([actorId])
}